{
  "name": "my-supervisor",
  "version": "1.0.0",
  "description": "A supervisord-like process manager for Node.js with REST API",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "build:deb": "node-deb --",
    "ctl": "node bin/ctl.js"
  },
  "bin": {
    "my-supervisor-ctl": "bin/ctl.js",
    "ctl": "bin/ctl.js"
  },
  "node-deb": {
    "entry": "src/index.js",
    "init": "systemd",
    "daemon": true,
    "user": "root"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "morgan": "^1.10.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "node-deb": "^0.10.7",
    "nodemon": "^3.1.14"
  }
}
